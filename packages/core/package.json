{
  "name": "@signakit/flags-core",
  "version": "1.3.0",
  "description": "Shared types and functions for SignaKit Feature Flags SDKs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignaKit/flags-js.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.6"
  }
}