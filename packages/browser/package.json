{
  "name": "@signakit/flags-browser",
  "version": "1.2.0",
  "description": "Official Browser SDK for SignaKit Feature Flags",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignaKit/flags-js.git",
    "directory": "packages/browser"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@signakit/flags-core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  }
}