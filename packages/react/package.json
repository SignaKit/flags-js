{
  "name": "@signakit/flags-react",
  "version": "1.3.0",
  "description": "Official React SDK for SignaKit Feature Flags",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignaKit/flags-js.git",
    "directory": "packages/react"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@signakit/flags-core": "workspace:*"
  },
  "peerDependencies": {
    "@signakit/flags-browser": ">=1.3.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@signakit/flags-browser": "workspace:*",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  }
}